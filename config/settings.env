# Project configuration. Every script and the Airflow DAG source this file.
# If you ever move this folder, update PROJECT_ROOT (this one line) and nothing else.
#
# NOTE: this path intentionally contains a space ("Agentic Workflows "); it is
# the real folder location, so it stays quoted everywhere.
export PROJECT_ROOT="/Users/dev/Agentic Workflows /dm2-weather-pipeline"

# ---- Google Cloud / BigQuery ----------------------------------------------
# The Project ID from the Google Cloud console (under the srh-heidelberg.org org).
# Tentatively set to the existing Data-Engineering-2 project; change if you pick another.
export GCP_PROJECT_ID="data-engineering-2-481619"

# Location must be identical for every dataset and for the loaded data.
# Use the same value you picked when creating the "raw" dataset (US or EU).
export BQ_LOCATION="US"

# Raw landing dataset/table (written by load_bigquery.py, read by dbt as a source).
export BQ_RAW_DATASET="raw"
export BQ_RAW_TABLE="weather_readings"

# Dataset that dbt builds its models into (staging views + mart tables).
export BQ_DBT_DATASET="weather"

# Service account key downloaded from the console. The BigQuery client and dbt
# both read this variable automatically.
export GOOGLE_APPLICATION_CREDENTIALS="${PROJECT_ROOT}/config/dbt-sa-key.json"

# ---- Spark / Java ----------------------------------------------------------
export JAVA_HOME="/opt/homebrew/Cellar/openjdk@11/11.0.27/libexec/openjdk.jdk/Contents/Home"

# ---- Local data paths ------------------------------------------------------
export LANDING_DIR="${PROJECT_ROOT}/data/landing"
export PROCESSED_DIR="${PROJECT_ROOT}/data/processed"
export CHECKPOINT_DIR="${PROJECT_ROOT}/data/checkpoints/spark"
